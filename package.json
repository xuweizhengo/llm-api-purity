    "private":  false,
    "scripts":  {
                    "start":  "node server.js",
                    "dev":  "node --watch server.js",
                    "import:ecosystem":  "node scripts/import-ecosystem.mjs",
                    "import:proxyai":  "node scripts/import-proxyai-sites.mjs",
                    "check":  "node --check server.js \u0026\u0026 node --check src/store.js \u0026\u0026 node --check public/app.js"
                },
